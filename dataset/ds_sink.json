{
	"name": "ds_sink",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureBlobStorage3",
			"type": "LinkedServiceReference"
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@concat(\nsubstring(item().name,0,lastIndexOf(item().name,'.')),\n'_',\nformatDateTime(utcNow(),'yyyyMMdd_HHmmss'),\n'.',\nlast(split(item().name,'.'))\n)",
					"type": "Expression"
				},
				"container": "sink"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "employee_id",
				"type": "String"
			},
			{
				"name": "employee_name",
				"type": "String"
			},
			{
				"name": "department",
				"type": "String"
			},
			{
				"name": "state",
				"type": "String"
			},
			{
				"name": "salary",
				"type": "String"
			},
			{
				"name": "age",
				"type": "String"
			},
			{
				"name": "bonus",
				"type": "String"
			}
		]
	}
}