									"inputs": [
										{
											"referenceName": "ds_multicsv",
											"type": "DatasetReference",
											"parameters": {
												"filename": {
													"value": "@item().sourcefile",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "AzureSqlTable2",
											"type": "DatasetReference",
											"parameters": {
												"tablename": {
													"value": "@item().sinkfile",
													"type": "Expression"
												},
												"schemaname": {
													"value": "@item().tableschema",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
